<launch>
  <arg name="launch_driver" default="true"/>
  <arg name="video_device" default="/dev/video0"/>
  <arg name="image_width" default="640"/>
  <arg name="image_height" default="480"/>
  <arg name="framerate" default="30.0"/>
  <arg name="pixel_format" default="mjpeg2rgb"/>
  <arg name="camera_frame_id" default="camera_front/camera_link"/>

  <group if="$(var launch_driver)">
    <node pkg="usb_cam" exec="usb_cam_node_exe" name="camera_front" output="screen">
      <param name="video_device" value="$(var video_device)"/>
      <param name="image_width" value="$(var image_width)"/>
      <param name="image_height" value="$(var image_height)"/>
      <param name="framerate" value="$(var framerate)"/>
      <param name="pixel_format" value="$(var pixel_format)"/>
      <param name="camera_frame_id" value="$(var camera_frame_id)"/>

      <remap from="image_raw" to="/camera/camera_front/image_raw"/>
      <remap from="camera_info" to="/camera/camera_front/camera_info"/>
    </node>
  </group>
</launch>
